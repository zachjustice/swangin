{
  "name": "swangin",
  "version": "1.0.0",
  "description": "Grappling multiplayer discord activity",
  "private": true,
  "license": "ISC",
  "author": "Zach Justice",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace server run dev",
    "build": "npm --workspace client run build && npm --workspace server run build",
    "screenshot": "node scripts/screenshot-prototype.mjs",
    "measure": "node scripts/measure-silhouette.mjs",
    "score": "npm run screenshot && npm run measure"
  },
  "devDependencies": {
    "npm-run-all2": "^7.0.2",
    "playwright": "^1.61.0",
    "pngjs": "^7.0.0"
  }
}
