# Copy to .env and fill in. The server loads .env from repo root.
# [HUMAN] Create the Discord app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Same client id, exposed to the browser via Vite (VITE_ prefix).
VITE_DISCORD_CLIENT_ID=

# NOTE: at least one Redirect URI must be registered under OAuth2 → Redirects in
# the Discord Developer Portal (e.g. http://localhost), but no code path sends
# redirect_uri — Discord's RPC OAuth flow forbids it.
